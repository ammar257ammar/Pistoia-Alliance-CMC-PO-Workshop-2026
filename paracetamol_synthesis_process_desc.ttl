    obo:BFO_0000177 ex:Stage_1_Synthesis ;
    iof:prescribes <http://example.org/paracetamol-recipe/process/operation/React> .

ex:Op_14_Fill a iofc:RecipeProcessOperation ;
    rdfs:label "Op 14: Fill" ;
    obo:BFO_0000177 ex:Stage_1_Synthesis ;
    iof:prescribes <http://example.org/paracetamol-recipe/process/operation/Fill> .

ex:Op_12_Staging a iofc:RecipeProcessOperation ;
    rdfs:label "Op 12: Staging" ;
    obo:BFO_0000177 ex:Stage_1_Synthesis .

ex:Op_13_Fill a iofc:RecipeProcessOperation ;
    rdfs:label "Op 13: Fill" ;
